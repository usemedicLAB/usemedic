{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    { "source": "/((?!assets/|favicon\\.ico|robots\\.txt|sitemap\\.xml).*)", "destination": "/api" }
  ]
}
